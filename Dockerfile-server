# Build stage
FROM maven:3.9-eclipse-temurin-17 AS build

WORKDIR /app

# 配置 Maven 阿里云镜像
RUN mkdir -p ~/.m2 && echo '<?xml version="1.0" encoding="UTF-8"?>\
<settings xmlns="http://maven.apache.org/SETTINGS/1.2.0">\
  <mirrors>\
    <mirror>\
      <id>aliyun-maven</id>\
      <mirrorOf>central</mirrorOf>\
      <name>Aliyun Maven</name>\
      <url>https://maven.aliyun.com/repository/public</url>\n\
    </mirror>\n\
  </mirrors>\n\
</settings>' > ~/.m2/settings.xml

# Copy pom files
COPY pom.xml .
COPY agent-common/pom.xml agent-common/
COPY agent-server/pom.xml agent-server/
COPY agent-client/pom.xml agent-client/

# Download dependencies
RUN mvn dependency:go-offline -B

# Copy source code
COPY agent-common/src agent-common/src
COPY agent-server/src agent-server/src
COPY agent-client/src agent-client/src

# Build the project
RUN mvn clean package -DskipTests -B

# Runtime stage
FROM eclipse-temurin:17-jre-alpine

WORKDIR /app

# Install wget for healthcheck
RUN apk add --no-cache wget

# Copy the built jar
COPY --from=build /app/agent-server/target/*.jar app.jar

# Expose port
EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=60s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:8080/api/health || exit 1

# Run the application
ENTRYPOINT ["java", "-jar", "app.jar"]
